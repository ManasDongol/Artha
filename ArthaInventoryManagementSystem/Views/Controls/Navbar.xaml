<UserControl x:Class="ArthaInventoryManagementSystem.Controls.Navbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="White"
            BorderBrush="#D9D9D9"
            BorderThickness="0,0,1,0">

        <Grid Width="220">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Logo / Title -->
           

            <!-- Navigation -->
            <StackPanel Grid.Row="1"
                        Margin="10">

                <Button Content="Dashboard"
                        Height="42"
                        Background="Transparent"
                        BorderThickness="0"
                        BorderBrush="Transparent"
                        Click="OpenDashboard"/>

                <Button Content="Products"
                        Height="42"
                        Margin="0,5"
                        Background="Transparent"
                        BorderThickness="0"
                        BorderBrush="Transparent"
                        Click="OpenProducts"/>

                <Button Content="Billing"
                        Height="42"
                        Background="Transparent"
                        BorderThickness="0"
                        BorderBrush="Transparent"
                        Click="OpenBilling"/>

                <Button Content="Songs"
                        Height="42"
                        Background="Transparent"
                        BorderThickness="0"
                        BorderBrush="Transparent"
                        Click="OpenSongs"/>

            </StackPanel>

            <!-- Logout -->
            <Button Grid.Row="2"
                    Content="Logout"
                    Height="42"
                    Margin="10,0,10,20"
                    BorderBrush="#D9D9D9"
                    Background="Transparent"/>

        </Grid>

    </Border>
</UserControl>