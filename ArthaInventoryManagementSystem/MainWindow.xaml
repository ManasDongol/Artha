<Window x:Class="ArthaInventoryManagementSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ArthaInventoryManagementSystem"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Text="Artha Inventory System"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="10"/>

        <!-- Content -->
        <StackPanel Grid.Row="1" Margin="10">
            <Button Content="Manage Inventory" Height="40" Margin="0,5"/>
            <Button Content="Manage Customers" Height="40" Margin="0,5"/>
            <Button Content="View Reports" Height="40" Margin="0,5"/>
        </StackPanel>
    </Grid>
</Window>
